# Название и описание сущности
ent-BluespaceTimerBeacon = блюспейс-установка снабжения
    .desc = Высокотехнологичный маяк для материализации грузов из глубокого блюспейса. Требует долгой синхронизации.

# Сообщения в интерфейсе (Popups)
timer-crate-startup = Протокол материализации запущен!
timer-crate-status-remaining = До прибытия груза: { $min } мин. { $sec } сек.
timer-crate-status-cooldown = Система перегрета. Требуется охлаждение компонентов.

# Глобальные анонсы (Announcements)
timer-crate-announcement-sender = Служба снабжения
timer-crate-announcement-start = Внимание! Обнаружена активация блюспейс-маяка. Прибытие груза ожидается через 15 минут.
timer-crate-announcement-finish = Синхронизация завершена. Груз материализован.
