<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client.CrateTimer.UI.TimerCrateWindow"
               Title="Управление маяком"
               MinSize="250 150">
    <BoxContainer Orientation="Vertical" Margin="10">
        <Label Name="StatusLabel" Text="Статус: Idle" />
        <Label Name="TimeLabel" Text="Осталось: 00:00" />
        <ProgressBar Name="TimerBar" MinValue="0" MaxValue="1" MinSize="0 20" Margin="0, 5" />
        <Button Name="ActivateButton" Text="АКТИВИРОВАТЬ" />
    </BoxContainer>
</DefaultWindow>
